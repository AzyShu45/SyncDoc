
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SYNC DOC SECURITY RULES - PRODUCTION READY
     * Optimized for membership-based access and real-time collaboration.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Robust helper to check if the user is a member of the document
    function isMember(docData) {
      return isSignedIn() && 
             docData != null && 
             'members' in docData && 
             request.auth.uid in docData.members;
    }

    // Helper to check for specific roles
    function hasRole(docData, roles) {
      return isMember(docData) && docData.members[request.auth.uid] in roles;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isOwner(userId);
      allow create, update, delete: if isOwner(userId);
    }

    match /documents/{documentId} {
      // Allow creation if the user sets themselves as the OWNER
      allow create: if isSignedIn() && 
                    request.resource.data.members[request.auth.uid] == 'OWNER' &&
                    request.resource.data.ownerId == request.auth.uid;

      // Access based on membership in the 'members' map
      // Using 'read' which covers both 'get' and 'list'
      allow read: if isMember(resource.data) || (resource == null && isSignedIn());
      
      // Allow updates if user is OWNER or EDITOR
      allow update: if hasRole(resource.data, ['OWNER', 'EDITOR']);
      
      // Allow deletion only by the OWNER
      allow delete: if hasRole(resource.data, ['OWNER']);

      match /messages/{messageId} {
        // Robust sub-collection check using parent document path
        allow read: if isSignedIn() && isMember(get(/databases/$(database)/documents/documents/$(documentId)).data);
        allow create: if isSignedIn() && hasRole(get(/databases/$(database)/documents/documents/$(documentId)).data, ['OWNER', 'EDITOR']);
        allow update, delete: if false;
      }

      match /files/{fileId} {
        allow read: if isSignedIn() && isMember(get(/databases/$(database)/documents/documents/$(documentId)).data);
        allow write: if isSignedIn() && hasRole(get(/databases/$(database)/documents/documents/$(documentId)).data, ['OWNER', 'EDITOR']);
      }
    }

    match /permissions/{permissionId} {
      allow read, write: if isSignedIn();
    }
  }
}
