
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SYNC DOC SECURITY RULES - PRODUCTION READY PROTOTYPE
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMember(data) {
      return isSignedIn() && (
        (data.members != null && data.members[request.auth.uid] != null) || 
        (data.documentMembers != null && data.documentMembers[request.auth.uid] != null)
      );
    }

    function hasRole(data, allowedRoles) {
      return isSignedIn() && (
        (data.members != null && data.members[request.auth.uid] in allowedRoles) || 
        (data.documentMembers != null && data.documentMembers[request.auth.uid] in allowedRoles)
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /documents/{documentId} {
      // Allow list if signed in - the app filters by membership in the query
      allow list: if isSignedIn();
      // Allow get if user is in the members map
      allow get: if isMember(resource.data);
      // Allow create if user sets themselves as owner
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      // Allow update if user has OWNER or EDITOR role
      allow update: if hasRole(resource.data, ['OWNER', 'EDITOR']);
      // Allow delete if user is OWNER
      allow delete: if hasRole(resource.data, ['OWNER']);

      match /messages/{messageId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() && resource.data.senderId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }

      match /files/{fileId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
      }
    }

    match /permissions/{permissionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
