
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SYNC DOC SECURITY RULES - RBAC ENFORCED
     * Roles: OWNER, EDITOR, VIEWER
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is a member of the document via denormalized map
    function getDocData(docId) {
      return get(/databases/$(database)/documents/documents/$(docId)).data;
    }

    function isMember(docData) {
      return isSignedIn() && 
             docData != null && 
             'members' in docData && 
             request.auth.uid in docData.members;
    }

    function hasRole(docData, roles) {
      return isMember(docData) && docData.members[request.auth.uid] in roles;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /documents/{documentId} {
      // Create: Must set themselves as OWNER
      allow create: if isSignedIn() && 
                    request.resource.data.members[request.auth.uid] == 'OWNER' &&
                    request.resource.data.ownerId == request.auth.uid;

      // Read: Any member can read
      allow read: if isMember(resource.data) || (resource == null && isSignedIn());
      
      // Update: OWNER or EDITOR only. 
      // Note: VIEWER attempting update triggers 403.
      allow update: if hasRole(resource.data, ['OWNER', 'EDITOR']);
      
      // Delete: OWNER only.
      allow delete: if hasRole(resource.data, ['OWNER']);

      // Sub-collections inherit RBAC logic via parent lookups
      match /messages/{messageId} {
        allow read: if isSignedIn() && isMember(getDocData(documentId));
        // Only OWNER and EDITOR can send messages. VIEWER gets 403.
        allow create: if isSignedIn() && hasRole(getDocData(documentId), ['OWNER', 'EDITOR']);
        allow update, delete: if false;
      }

      match /files/{fileId} {
        allow read: if isSignedIn() && isMember(getDocData(documentId));
        // Only OWNER and EDITOR can upload files. VIEWER gets 403.
        allow write: if isSignedIn() && hasRole(getDocData(documentId), ['OWNER', 'EDITOR']);
      }
    }

    match /permissions/{permissionId} {
      allow read: if isSignedIn();
      // Only the document owner should be able to manage permission records
      // In this prototype, we allow authenticated writes to permissions, 
      // but document-level access is controlled by the 'members' map above.
      allow write: if isSignedIn();
    }
  }
}
