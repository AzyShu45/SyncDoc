
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getDocData(docId) {
      return get(/databases/$(database)/documents/documents/$(docId)).data;
    }

    // RBAC helpers
    function isMember(docData) {
      return isSignedIn() && docData != null && 'members' in docData && request.auth.uid in docData.members;
    }

    function hasRole(docData, roles) {
      return isMember(docData) && docData.members[request.auth.uid] in roles;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Document Rules
    match /documents/{documentId} {
      // Create: Anyone signed in can create, must set themselves as OWNER
      allow create: if isSignedIn();
      
      // Read: Must be a member (OWNER, EDITOR, or VIEWER)
      allow read: if isMember(resource.data);
      
      // Update: Only OWNER or EDITOR can change document content/title
      // Note: Changing permissions (members map) should ideally be restricted to OWNER
      allow update: if hasRole(resource.data, ['OWNER', 'EDITOR']);
      
      // Delete: Only OWNER can delete
      allow delete: if hasRole(resource.data, ['OWNER']);

      // Sub-collection: Messages
      match /messages/{messageId} {
        allow read: if isMember(getDocData(documentId));
        // Only OWNER or EDITOR can send messages or upload files (messages with fileUrl)
        allow create: if hasRole(getDocData(documentId), ['OWNER', 'EDITOR']);
      }

      // Sub-collection: Presence
      match /presence/{userId} {
        allow read: if isMember(getDocData(documentId));
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
