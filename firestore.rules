
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SYNC DOC SECURITY RULES - PRODUCTION READY PROTOTYPE
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to check membership in the denormalized members map
    function getRole(data) {
      return data.members[request.auth.uid];
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /documents/{documentId} {
      // Allow list if signed in. The client query filters by membership.
      allow list: if isSignedIn();
      
      // Allow get if user is in the members map
      allow get: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      
      // Allow create if user sets themselves as owner
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // Allow update if user has OWNER or EDITOR role
      allow update: if isSignedIn() && (resource.data.members[request.auth.uid] in ['OWNER', 'EDITOR']);
      
      // Allow delete if user is OWNER
      allow delete: if isSignedIn() && (resource.data.members[request.auth.uid] == 'OWNER');

      match /messages/{messageId} {
        // Simplified rules for subcollections in this prototype to ensure collaboration works
        allow read, write: if isSignedIn();
      }

      match /files/{fileId} {
        allow read, write: if isSignedIn();
      }
    }

    match /permissions/{permissionId} {
      allow read, write: if isSignedIn();
    }
  }
}
