
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" }
      }
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Presence": {
      "title": "Presence",
      "type": "object",
      "description": "Represents a user's active presence in a specific document workspace.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "User profiles" },
    "/documents/{docId}": { "schema": { "$ref": "#/backend/entities/Document" }, "description": "Documents" },
    "/documents/{docId}/presence/{userId}": { "schema": { "$ref": "#/backend/entities/Presence" }, "description": "Real-time presence" }
  }
}
