
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "description": "Collaborative document with embedded RBAC members map.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { 
          "type": "object",
          "description": "Map of userId to Role (OWNER | EDITOR | VIEWER)"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Presence": {
      "title": "Presence",
      "type": "object",
      "description": "Real-time user status within a document workspace.",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "documentId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "User profiles" },
    "/documents/{docId}": { "schema": { "$ref": "#/backend/entities/Document" }, "description": "Documents" },
    "/documents/{docId}/presence/{userId}": { "schema": { "$ref": "#/backend/entities/Presence" }, "description": "Real-time presence heartbeats" },
    "/documents/{docId}/messages/{messageId}": { "schema": { "$ref": "#/backend/entities/Message" }, "description": "Chat and file sharing history" }
  }
}
